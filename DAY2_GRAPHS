     0: [1, 2],
     1: [0, 3],
     2: [0, 3],
     3: [1, 2]
 }

 # Method 2: List of lists (when nodes are 0-indexed integers)
 n = 4
 graph = [[] for _ in range(n)]
 for u, v in edges:
     graph[u].append(v)
     graph[v].append(u)    # remove for directed graph

 # Weighted adjacency list
 graph = {}
 for u, v, w in edges:
     if u not in graph: graph[u] = []
     if v not in graph: graph[v] = []
     graph[u].append((v, w))
      graph[v].append((u, w))
Space: O(V + E) Default choice for almost every interview and competitive programming
problem.

